# ─────────────────────────────────────────────────────────────
# n8n SMB Agent Template — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Client Branding ───────────────────────────────────────
CLIENT_ID=acme-corp
CLIENT_NAME="Acme Corporation"
BRAND_VOICE="professional, helpful, and approachable"
TZ=Australia/Sydney

# ─── n8n Core Config ───────────────────────────────────────
N8N_HOST=n8n.yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-to-a-strong-password

# ─── Database ──────────────────────────────────────────────
DB_USER=n8n
DB_PASSWORD=change-me-to-a-strong-db-password
DB_NAME=n8n
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# ─── Meta / Facebook Graph API ─────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_AD_ACCOUNT_ID=act_123456789
META_SYSTEM_USER_TOKEN=your_system_user_token

# ─── Squarespace API ───────────────────────────────────────
SQUARESPACE_API_KEY=your_squarespace_api_key
SQUARESPACE_SITE_ID=your_squarespace_site_id

# ─── LLM Providers ─────────────────────────────────────────
# Ollama (local/cloud — cheap routine tasks)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# SiliconFlow (OpenAI-compatible — cheap/routine via China)
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Anthropic Claude (complex reasoning, high-quality output)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Grok / xAI (fallback, OpenAI-compatible)
GROK_API_KEY=xai-your-grok-key
GROK_BASE_URL=https://api.x.ai/v1

# OpenAI (general purpose, optional)
OPENAI_API_KEY=sk-your-openai-key

# ─── Google Sheets (execution logging) ─────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
LOG_SPREADSHEET_ID=your_google_sheet_id
LOG_SHEET_NAME=ExecutionLog

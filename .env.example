# ─────────────────────────────────────────────────────────────
# n8n SMB Agent Template — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Client Branding ───────────────────────────────────────
CLIENT_ID=acme-corp
CLIENT_NAME="Acme Corporation"
CLIENT_LOCATION="Sydney, Australia"
CLIENT_BUSINESS_TYPE="professional services"
BRAND_VOICE="professional, helpful, and approachable"
TZ=Australia/Sydney

# ─── n8n Core Config ───────────────────────────────────────
# When deploying to Hostinger VPS, set N8N_HOST to your domain
N8N_HOST=n8n.yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-to-a-strong-password

# ─── n8n Version Pinning ────────────────────────────────────
# Pin to a specific version in production.  Check latest:
#   https://hub.docker.com/r/n8nio/n8n/tags
# Omitting or setting to "latest" is fine for local dev.
N8N_VERSION=latest

# ─── Database ──────────────────────────────────────────────
DB_USER=n8n
DB_PASSWORD=change-me-to-a-strong-db-password
DB_NAME=n8n
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# ─── Docker Project Name (for multi-client isolation) ──────
# Set to a unique name per client to isolate volumes/networks
# docker compose -p client-name up -d
COMPOSE_PROJECT_NAME=n8n-smb

# ─── Server / VPS Info (Hostinger) ──────────────────────────
# Used for firewall config, logging, and health checks.
SERVER_IP=your.server.ip.address
DOMAIN=yourdomain.com

# ─── Meta / Facebook Graph API ─────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_AD_ACCOUNT_ID=act_123456789
META_SYSTEM_USER_TOKEN=your_system_user_token
# Custom verify token for Messenger webhook (shared with Meta)
META_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string
# For Instagram publishing (optional):
# META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# ─── Squarespace API ───────────────────────────────────────
SQUARESPACE_API_KEY=your_squarespace_api_key
SQUARESPACE_SITE_ID=your_squarespace_site_id

# ─── LLM Providers ─────────────────────────────────────────
# At minimum, configure ONE provider below.

# ── Ollama (Local — free, runs on your Mac or VPS) ──────
# local:  http://host.docker.internal:11434  (OrbStack / Docker Desktop)
# cloud:  https://your-ollama-instance.com  (if self-hosting on VPS)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Ollama Cloud (optional — if using a hosted Ollama) ──
# e.g. https://ollama.ai or a cloud-hosted instance
# OLLAMA_CLOUD_URL=https://your-ollama-cloud.com
# OLLAMA_CLOUD_API_KEY=your-ollama-api-key

# ── SiliconFlow (OpenAI-compatible — cheap/routine LLMs) ─
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── Anthropic Claude (complex reasoning, high quality) ───
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Grok / xAI (OpenAI-compatible fallback) ──────────────
GROK_API_KEY=xai-your-grok-key
GROK_BASE_URL=https://api.x.ai/v1

# ── OpenAI (general purpose, optional) ───────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Google Sheets (execution logging) ─────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
LOG_SPREADSHEET_ID=your_google_sheet_id
LOG_SHEET_NAME=ExecutionLog

# ─── Production Hardening (Hostinger / any VPS) ──────────────
# Uncomment and set these for production:
# N8N_SECURE_COOKIE=true                    # Only send cookies over HTTPS
# N8N_SMTP_HOST=smtp.your-provider.com      # SMTP for password resets / alerts
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=alerts@yourdomain.com
# N8N_SMTP_PASS=your-smtp-password
# N8N_SMTP_SENDER=alerts@yourdomain.com

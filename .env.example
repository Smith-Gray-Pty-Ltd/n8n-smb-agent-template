# ─────────────────────────────────────────────────────────────
# n8n SMB Agent Template — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in your values.  Never commit .env.
#
# QUICK START (local dev):
#   1. cp .env.example .env
#   2. Set N8N_ENCRYPTION_KEY:  openssl rand -hex 16
#   3. Set N8N_HOST=localhost, N8N_PROTOCOL=http
#   4. Configure at least ONE LLM provider below
#   5. docker compose up -d
#
# HOSTINGER VPS:
#   1. Set N8N_HOST=your-domain.com, N8N_PROTOCOL=https
#   2. Set SERVER_IP, DOMAIN, COMPOSE_PROJECT_NAME
#   3. Generate strong DB_PASSWORD and REDIS_PASSWORD
#   4. Pin N8N_VERSION to a stable release
#   5. See HOSTINGER-DEPLOY.md for full guide
# ─────────────────────────────────────────────────────────────

# ─── Client Branding ───────────────────────────────────────
CLIENT_ID=acme-corp
CLIENT_NAME="Acme Corporation"
CLIENT_LOCATION="Sydney, Australia"
CLIENT_BUSINESS_TYPE="professional services"
BRAND_VOICE="professional, helpful, and approachable"
TZ=Australia/Sydney

# ─── n8n Core Config ───────────────────────────────────────
N8N_HOST=n8n.yourdomain.com        # localhost for local dev
N8N_PORT=5678
N8N_PROTOCOL=https                 # http for local dev, https for VPS
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-to-a-strong-password

# ─── n8n Version Pinning ────────────────────────────────────
# Pin to a stable release in production.
# Check latest tags: https://hub.docker.com/r/n8nio/n8n/tags
N8N_VERSION=latest

# ─── Database ──────────────────────────────────────────────
DB_USER=n8n
DB_PASSWORD=change-me-to-a-strong-db-password
DB_NAME=n8n
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# ─── Docker Project Name ───────────────────────────────────
# Used to isolate multiple client stacks on one VPS.
# Each client gets their own volumes, network, and containers.
COMPOSE_PROJECT_NAME=n8n-smb

# ─── Hostinger VPS ──────────────────────────────────────────
# Your VPS public IP and domain — used for health checks and logging.
SERVER_IP=your.server.ip.address
DOMAIN=yourdomain.com

# ─── Meta / Facebook Graph API ─────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_AD_ACCOUNT_ID=act_123456789
META_SYSTEM_USER_TOKEN=your_system_user_token
META_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string
# Optional — Instagram Business Account ID for publishing:
# META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# ─── Squarespace API ───────────────────────────────────────
SQUARESPACE_API_KEY=your_squarespace_api_key
SQUARESPACE_SITE_ID=your_squarespace_site_id

# ─── LLM Providers ─────────────────────────────────────────
# Configure at least ONE provider.  The LLM Router has fallbacks.
#
# Cost comparison (per 1K tokens):
#   Ollama (local)        $0
#   SiliconFlow Qwen       ~$0.0007
#   SiliconFlow DeepSeek   ~$0.0014
#   Grok (xAI)             ~$0.003
#   Anthropic Claude       ~$0.015
#   OpenAI GPT-4o          ~$0.015

# ── Ollama (local or self-hosted) ────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Ollama Cloud (optional hosted instance) ──────────────
# OLLAMA_CLOUD_URL=https://your-ollama-cloud.com
# OLLAMA_CLOUD_API_KEY=your-ollama-api-key

# ── SiliconFlow (OpenAI-compatible — cheap/routine) ──────
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── Anthropic Claude (complex reasoning) ─────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Grok / xAI (OpenAI-compatible fallback) ──────────────
GROK_API_KEY=xai-your-grok-key
GROK_BASE_URL=https://api.x.ai/v1

# ── OpenAI (general purpose, optional) ───────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Google Sheets (execution logging) ─────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
LOG_SPREADSHEET_ID=your_google_sheet_id
LOG_SHEET_NAME=ExecutionLog

# ─── Production Hardening ────────────────────────────────────
# Uncomment for VPS deployments:
# N8N_SECURE_COOKIE=true
# N8N_SMTP_HOST=smtp.your-provider.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=alerts@yourdomain.com
# N8N_SMTP_PASS=your-smtp-password
# N8N_SMTP_SENDER=alerts@yourdomain.com
# N8N_METRICS=true                           # Prometheus metrics
# N8N_METRICS_PREFIX=n8n_
# N8N_PAYLOAD_SIZE_MAX=16                    # MB — adjust for large attachments

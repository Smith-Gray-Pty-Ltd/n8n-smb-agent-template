    {
      "parameters": {
        "jsCode": "// Parse Meta Messenger webhook payload\n// Meta sends the webhook as a GET verification first, then POST for messages\nconst data = $input.first().json;\nconst clientId = $env.CLIENT_ID || 'unknown';\n\n// Handle webhook verification (GET request)\nif ($input.first().params && $input.first().params['hub.mode'] === 'subscribe') {\n  const verifyToken = $input.first().params['hub.verify_token'];\n  const challenge = $input.first().params['hub.challenge'];\n  \n  // Verify with your configured token\n  if (verifyToken === ($env.META_WEBHOOK_VERIFY_TOKEN || 'n8n-meta-verify')) {\n    return { verified: true, challenge: parseInt(challenge) };\n  }\n  return { verified: false, error: 'Invalid verify token' };\n}\n\n// Parse message events from the POST body\nconst entries = data.entry || [];\nconst messages = [];\n\nfor (const entry of entries) {\n  const messagingEvents = entry.messaging || [];\n  for (const event of messagingEvents) {\n    const sender = event.sender || {};\n    const recipient = event.recipient || {};\n    const message = event.message || {};\n    const postback = event.postback || {};\n    \n    messages.push({\n      sender_id: sender.id,\n      recipient_id: recipient.id,\n      message_id: message.mid || null,\n      text: message.text || postback.title || postback.payload || '[non-text message]',\n      timestamp: event.timestamp || Date.now(),\n      client_id: clientId,\n      message_type: message.attachments ? 'attachment' : 'text',\n      attachments: message.attachments || []\n    });\n  }\n}\n\nif (messages.length === 0) {\n  return { status: 'no_messages', client_id: clientId };\n}\n\nreturn messages;"
      },

    {
      "parameters": {
        "jsCode": "// Prepare input for LLM Router sub-workflow\nconst item = $input.first().json;\nconst brandVoice = $env.BRAND_VOICE || 'professional and friendly';\nconst clientName = $env.CLIENT_NAME || 'our team';\n\nlet context = '';\nlet toneGuidance = '';\n\nswitch (item.response_type) {\n  case 'pricing_inquiry':\n    context = 'The user is asking about pricing. Be transparent about cost ranges but encourage them to book a consultation for an exact quote. Include a call to action.';\n    toneGuidance = 'Helpful, transparent, and consultative';\n    break;\n  case 'sales_inquiry':\n    context = 'The user is showing buying intent. Be enthusiastic, highlight key benefits, and guide them toward the next step (booking a call or making a purchase). Include a clear call to action.';\n    toneGuidance = 'Enthusiastic and action-oriented';\n    break;\n  case 'complaint':\n    context = 'The user is unhappy. Be empathetic, apologize sincerely, assure them we take this seriously, and provide a clear path to resolution (human follow-up). Do NOT be defensive.';\n    toneGuidance = 'Empathetic, calm, and solution-focused';\n    break;\n  default:\n    context = 'The user has a general question. Be helpful, warm, and guide them to the right resource or next step.';\n    toneGuidance = 'Warm and helpful';\n}\n\nreturn {\n  task_type: item.task_type || 'routine',\n  user_message: `User message: \"${item.text}\"\\n\\nContext: ${context}\\n\\nTone guidance: ${toneGuidance}. Brand: ${brandVoice}. Sign as ${clientName}.`,\n  context: context,\n  sender_id: item.sender_id,\n  response_type: item.response_type,\n  client_id: item.client_id\n};"
      },

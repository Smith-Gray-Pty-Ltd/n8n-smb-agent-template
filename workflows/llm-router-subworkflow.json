    {
      "parameters": {
        "jsCode": "// Build system prompt with brand voice injection\nconst brandVoice = $input.first().json.brand_voice;\nconst context = $input.first().json.context;\nconst userMessage = $input.first().json.user_message;\nconst clientName = $input.first().json.client_name;\n\nconst systemPrompt = `You are a helpful assistant for ${clientName}. Brand voice: ${brandVoice}. Be concise, accurate, and match the brand voice exactly. Do not make up information. If unsure, say so.`;\n\n// For Ollama, use a combined prompt (no system/user split)\nconst ollamaPrompt = context\n  ? `${systemPrompt}\\n\\nContext: ${context}\\n\\nUser: ${userMessage}\\n\\nAssistant:`\n  : `${systemPrompt}\\n\\nUser: ${userMessage}\\n\\nAssistant:`;\n\nreturn {\n  system_prompt: systemPrompt,\n  ollama_prompt: ollamaPrompt,\n  user_message: userMessage,\n  task_type: $input.first().json.task_type,\n  brand_voice: brandVoice,\n  client_id: $input.first().json.client_id\n};"
      },
      "id": "b1a2c3d4-e5f6-7890-abcd-ef1234560003",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.task_type }}",
        "rules": {
          "rules": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "routine",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.task_type }}",
                    "rightValue": "analysis",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,

      "id": "b1a2c3d4-e5f6-7890-abcd-ef1234560030",
      "name": "Grok (Fallback)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1050, 750],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Normalize LLM responses and implement fallback cascade\n// If primary provider returned an error, try the fallback\nconst items = $input.all();\nconst normalized = [];\n\nfor (const item of items) {\n  let responseText = '';\n  let provider = 'unknown';\n  let model = 'unknown';\n  let tokensUsed = 0;\n  let costEstimate = 0;\n\n  // ── Ollama response format ──\n  if (item.json.response && typeof item.json.response === 'string') {\n    provider = 'ollama';\n    model = item.json.model || 'llama3.2';\n    responseText = item.json.response;\n    tokensUsed = (item.json.eval_count || 0) + (item.json.prompt_eval_count || 0);\n    costEstimate = 0;\n  }\n  // ── Anthropic Claude response format ──\n  else if (item.json.content && Array.isArray(item.json.content)) {\n    provider = 'anthropic';\n    model = item.json.model || 'claude-3-5-sonnet';\n    const textBlocks = item.json.content.filter(b => b.type === 'text');\n    responseText = textBlocks.map(b => b.text).join('\\n');\n    tokensUsed = (item.json.usage?.input_tokens || 0) + (item.json.usage?.output_tokens || 0);\n    costEstimate = (tokensUsed / 1000) * 0.015;\n  }\n  // ── OpenAI-compatible format (SiliconFlow, Grok, OpenAI) ──\n  else if (item.json.choices && Array.isArray(item.json.choices) && item.json.choices.length > 0) {\n    if (item.json.model && item.json.model.includes('grok')) {\n      provider = 'grok';\n      model = item.json.model;\n      costEstimate = (tokensUsed / 1000) * 0.003;\n    } else if (item.json.model && item.json.model.includes('Qwen')) {\n      provider = 'siliconflow';\n      model = item.json.model;\n      costEstimate = (tokensUsed / 1000) * 0.0007;\n    } else if (item.json.model && item.json.model.includes('deepseek') || item.json.model && item.json.model.includes('DeepSeek')) {\n      provider = 'siliconflow';\n      model = item.json.model || 'deepseek-v3';\n      costEstimate = (tokensUsed / 1000) * 0.0014;\n    } else {\n      provider = 'openai-compatible';\n      model = item.json.model || 'unknown';\n    }\n    const choice = item.json.choices[0];\n    responseText = choice.message?.content || choice.text || '';\n    tokensUsed = item.json.usage?.total_tokens || 0;\n  }\n  // ── Error response ──\n  else if (item.json.error) {\n    provider = 'error';\n    model = 'failed';\n    responseText = `[LLM Error: ${item.json.error.message || JSON.stringify(item.json.error)}]`;\n  }\n  // ── String response ──\n  else if (typeof item.json === 'string') {\n    responseText = item.json;\n    provider = 'raw-string';\n  }\n\n  normalized.push({\n    json: {\n      success: responseText.length > 0 && !responseText.startsWith('[LLM Error'),\n      provider: provider,\n      model: model,\n      response: responseText,\n      tokens_used: tokensUsed,\n      cost_estimate: Math.round(costEstimate * 100000) / 100000,\n      task_type: item.json.task_type || $('Parse Input').item.json.task_type,\n      client_id: item.json.client_id || $('Parse Input').item.json.client_id\n    }\n  });\n}\n\nreturn normalized;"
      },
      "id": "b1a2c3d4-e5f6-7890-abcd-ef1234560040",
      "name": "Normalize Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 300]

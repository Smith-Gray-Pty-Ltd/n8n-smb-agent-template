        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"model\": \"llama3.2:latest\",\n  \"prompt\": \"{{ $json.ollama_prompt }}\",\n  \"stream\": false,\n  \"options\": {\n    \"temperature\": 0.7,\n    \"num_predict\": 1024\n  }\n}",
        "options": {
          "timeout": 60000,
          "response": {

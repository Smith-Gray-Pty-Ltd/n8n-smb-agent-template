              "value": "={{ $json.task_type }}"
            },
            {
              "name": "client_id",
              "value": "={{ $env.CLIENT_ID }}"
            }
          ]
        }
      },
      "id": "b1a2c3d4-e5f6-7890-abcd-ef1234560091",
      "name": "Fallback Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1250, 900]
    }
